sequenceDiagram
    autonumber

    actor U as User
    participant F as Frontend
    participant APP as Auth Service
    participant DOM as Domain Policies
    participant PG as PostgreSQL
    participant R as Redis Cache
    participant M as MongoDB Audit
    participant K as Kafka
    participant GA as Google Authenticator

    Note over U,K: 1. User registers account
    U->>F: Fill register form
    F->>APP: POST /auth/register {fullName, email, password}
    APP->>DOM: validateFullName / validateEmail / validatePassword
    DOM-->>APP: validation result

    alt Validation failed
        APP-->>F: 400 Validation error
        F-->>U: Show error
    else Validation passed
        APP->>PG: findByEmail(email)
        PG-->>APP: User exists / not found

        alt Email already exists
            APP->>M: Log REGISTER FAILED {email, EMAIL_ALREADY_EXISTS}
            APP-->>F: 409 Email already exists
            F-->>U: Show error
        else Email available
            APP->>APP: bcrypt.hash(password)
            APP->>APP: role = ADMIN_EMAILS.includes(email) ? admin : user
            APP->>PG: INSERT users {id, fullName, email, passwordHash, role}
            PG-->>APP: User created
            APP->>M: Log REGISTER SUCCESS {userId, email, role}
            APP->>K: Publish user.registered event
            APP-->>F: 201 {id, fullName, email, role, isTwoFactorEnabled: false}
            F-->>U: Account created
        end
    end

    Note over U,K: 2. User login (2FA disabled)
    U->>F: Fill login form
    F->>APP: POST /auth/login {email, password}
    APP->>DOM: validateEmail / validatePassword
    DOM-->>APP: validation result
    APP->>PG: findByEmail(email)
    PG-->>APP: User / null

    alt User not found or password wrong
        APP-->>F: 401 Invalid credentials
        F-->>U: Show error
    else Valid credentials - 2FA disabled
        APP->>APP: jwt.sign({userId, email, role}, accessSecret, 15m)
        APP->>APP: jwt.sign({userId, email, role}, refreshSecret, 7d)
        APP->>M: Log LOGIN SUCCESS {userId, email, viaTwoFactor: false}
        APP->>K: Publish user.logged_in event
        APP-->>F: 200 {status: SUCCESS, accessToken, refreshToken}
        F-->>U: Enter dashboard
    else Valid credentials - 2FA enabled
        APP->>APP: idGenerator.generate() → challengeId
        APP->>R: SET auth:login:challenge:{challengeId} TTL:300s
        R-->>APP: OK
        APP-->>F: 202 {status: REQUIRE_2FA, challengeId, userId, email}
        F-->>U: Show 2FA code input
    end

    Note over U,K: 3. User starts 2FA setup
    U->>F: Open 2FA setup
    F->>APP: POST /auth/2fa/init {userId}
    APP->>PG: findById(userId)
    PG-->>APP: User found
    APP->>APP: speakeasy.generateSecret()
    APP->>APP: qrcode.toDataURL(otpauthUrl)
    APP->>APP: idGenerator.generate() → setupToken
    APP->>R: SET auth:2fa:setup:{userId}:{setupToken} = secret TTL:300s
    R-->>APP: OK
    APP->>M: Log ENABLE_2FA_INIT INFO {userId, setupToken}
    APP-->>F: 200 {qrCodeDataUrl, manualEntryKey, setupToken}
    F-->>U: Display QR code

    Note over U,GA: 4. User adds account in Google Authenticator
    U->>GA: Scan QR code or enter manual key
    GA-->>U: Generate 6-digit code

    Note over U,K: 5. User confirms 2FA setup
    U->>F: Enter 6-digit code
    F->>APP: POST /auth/2fa/confirm {userId, setupToken, code}
    APP->>DOM: TwoFactorPolicy.validateCode(code)
    DOM-->>APP: validation result
    APP->>PG: findById(userId)
    PG-->>APP: User found
    APP->>R: GET auth:2fa:setup:{userId}:{setupToken}
    R-->>APP: secret / null

    alt Setup session expired (TTL 300s)
        APP-->>F: 400 Setup session expired or not found
        F-->>U: Show expired session message
    else Secret found
        APP->>APP: speakeasy.totp.verify(secret, code)

        alt Code invalid
            APP-->>F: 401 Invalid 2FA code
            F-->>U: Show invalid code message
        else Code valid
            APP->>PG: UPDATE users SET twoFactorSecret, isTwoFactorEnabled=true
            PG-->>APP: Updated
            APP->>R: DELETE auth:2fa:setup:{userId}:{setupToken}
            R-->>APP: Deleted
            APP->>M: Log ENABLE_2FA_CONFIRM SUCCESS {userId}
            APP->>K: Publish user.two_factor_enabled event
            APP-->>F: 200 {message, isTwoFactorEnabled: true}
            F-->>U: 2FA enabled successfully
        end
    end

    Note over U,K: 6. User login (2FA enabled) - verify code
    U->>GA: Open Google Authenticator
    GA-->>U: Generate 6-digit code
    U->>F: Enter 6-digit code
    F->>APP: POST /auth/login/2fa {email, challengeId, code}
    APP->>DOM: TwoFactorPolicy.validateCode(code)
    APP->>DOM: TwoFactorPolicy.validateChallengeId(challengeId)
    DOM-->>APP: validation result
    APP->>R: GET auth:login:challenge:{challengeId}
    R-->>APP: challenge data / null

    alt Challenge expired (TTL 300s)
        APP-->>F: 400 Login challenge expired or not found
        F-->>U: Show expired challenge message
    else Challenge found
        APP->>PG: findByEmail(email)
        PG-->>APP: User with twoFactorSecret
        APP->>APP: speakeasy.totp.verify(twoFactorSecret, code)

        alt Code invalid
            APP-->>F: 401 Invalid 2FA code
            F-->>U: Show invalid code message
        else Code valid
            APP->>APP: jwt.sign({userId, email, role}, accessSecret, 15m)
            APP->>APP: jwt.sign({userId, email, role}, refreshSecret, 7d)
            APP->>R: DELETE auth:login:challenge:{challengeId}
            R-->>APP: Deleted
            APP->>M: Log VERIFY_LOGIN_2FA SUCCESS {userId, email, role}
            APP->>K: Publish user.logged_in {viaTwoFactor: true}
            APP-->>F: 200 {accessToken, refreshToken}
            F-->>U: Enter dashboard
        end
    end